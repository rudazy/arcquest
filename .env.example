# Arc Terminal — environment variables
# Copy to .env.local and fill in actual values. Never commit real secrets.

# --- Privy (wallet connect) ---
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Arc testnet ---
NEXT_PUBLIC_ARC_RPC_URL=your_arc_rpc_url

# --- Contract deployment (Arc testnet) ---
# Set these before deploying contracts. NEVER commit real private keys.
PRIVATE_KEY=your_deployer_private_key
RPC_URL=your_arc_rpc_url
