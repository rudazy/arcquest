# Arc Terminal — environment variables
# Copy to .env.local and fill in actual values. Never commit real secrets.

# --- Privy (wallet connect) ---
# Get from https://dashboard.privy.io after creating an app
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Supabase ---
# Project URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon (publishable) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose or commit.
SUPABASE_SERVICE_ROLE_KEY=

# --- Arc testnet (Circle's stablecoin L1) ---
NEXT_PUBLIC_ARC_RPC_URL=
NEXT_PUBLIC_ARC_CHAIN_ID=
